<label
  class="<%= class_names("relative peer-checked/checkbox:border-indigo-600 peer-checked/checkbox:bg-indigo-50 peer-checked/checkbox:text-indigo-600 h-full w-full p-7 border border-indigo-200 flex items-center rounded-lg enabled:hover:bg-indigo-50", modifier_class) %>"
  role="button"
  for="<%= term.id %>"
  id="<%= dom_id term, :answer %>"
  data-result="<%= result %>"
  data-testid="answer_label"
>
  <%= label %>
  <% if render_audio_button? %>
    <div class="absolute right-2 top-2">
      <%= render(UI::AudioButtonComponent.new(audio: term.term_audio, audio_path: term_audio_path(term), label: 'Play term audio')) %>
    </div>
  <% end %>
</label>
